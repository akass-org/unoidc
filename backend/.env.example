# 数据库配置 (PostgreSQL only)
DATABASE_URL=postgres://user:password@localhost/oidc_provider

# 应用基础配置
APP_BASE_URL=http://localhost:3000
# 前端地址（可选，用于标准浏览器授权流程重定向）
FRONTEND_BASE_URL=http://localhost:5173
ISSUER=http://localhost:3000

# Session 配置
SESSION_SECRET=change-this-to-a-secure-random-string-in-production
COOKIE_DOMAIN=localhost

# Token 有效期（秒）
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=604800
SESSION_TTL=86400

# 文件存储路径
STORAGE_PATH=./storage

# 私钥加密密钥（至少32个字符）
PRIVATE_KEY_ENCRYPTION_KEY=change-this-to-32-char-encryption-key!!

# 日志级别
RUST_LOG=backend=debug,tower_http=debug

# SMTP 邮件配置（可选，不配置则邮件功能禁用，token 仅打印到日志）
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@your-domain.com
SMTP_TLS=true
